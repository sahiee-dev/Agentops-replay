# Copy to .env and fill in values — DO NOT commit .env with real keys

# LLM Provider (choose one)
OPENAI_API_KEY=your_key_here
# OR
ANTHROPIC_API_KEY=your_key_here
# OR
GEMINI_API_KEY=your_key_here

# Database (for backend ingestion service)
POSTGRES_USER=agentops
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=agentops_replay
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Backend API
AGENTOPS_DATABASE_URL=postgresql+asyncpg://agentops:your_secure_password@localhost:5432/agentops_replay
SECRET_KEY=your-super-secret-key-change-this-in-production

# Optional
LOG_LEVEL=INFO
